# Base de datos: SQLite por defecto en dev; PostgreSQL (Neon) en prod.
# Para Postgres: postgresql://user:pass@host/db  (se normaliza a postgresql+psycopg://)
DATABASE_URL=sqlite:///./dev.db

# URL pública base (para slugs compartibles, OG tags y fallback de media local).
PUBLIC_BASE_URL=http://localhost:8000

# Cloudflare R2 (S3-compatible). Si quedan vacías, el storage usa fallback local ./media_local.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Límite de tamaño para videos subidos (MB).
MAX_VIDEO_MB=25
