# --- Base de datos ---
# SQLite para dev local; PostgreSQL (Neon) para prod.
# Formato Postgres: postgresql://user:pass@host/db
DATABASE_URL=sqlite:///./dev.db

# --- App / seguridad ---
ENV=dev
PUBLIC_BASE_URL=http://localhost:8000
SECRET_KEY=YOUR_SECRET_KEY_HERE
CORS_ORIGINS=http://localhost:5173

# --- Cloudflare R2 ---
# Si quedan vacios, el storage usa fallback local ./media_local
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET=YOUR_BUCKET_NAME
R2_PUBLIC_URL=https://YOUR_PUBLIC_URL.r2.dev
R2_REGION=auto

# --- Media / optimizacion ---
MAX_IMAGE_MB=10
MAX_VIDEO_MB=25
IMAGE_MAX_SIDE=1080

# Pipeline de video — motor TTS: edge | espeak | piper | silent.
#   edge   = voz neuronal Microsoft (gratis, sin API key; lo más cercano a Loquendo). Requiere internet.
#   espeak = robótico clásico (requiere espeak-ng instalado).
#   silent = sin voz (dev/tests, no requiere nada).
TTS_ENGINE=edge
EDGE_VOICE=es-ES-AlvaroNeural
EDGE_RATE=+0%
ESPEAK_VOICE=es
ESPEAK_SPEED=165
# Solo si TTS_ENGINE=piper: ruta al modelo de voz .onnx.
PIPER_VOICE=

# Render del video: aspecto 9:16 (vertical) o 16:9, y fps de salida.
VIDEO_ASPECT=9:16
VIDEO_FPS=30
VIDEO_RATE_LIMIT=5
